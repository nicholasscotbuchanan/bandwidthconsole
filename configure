#!/bin/sh
# Configure script for bwtest — the Bandwidth Console (Java/Maven) and bwagent
# (Rust/Cargo).
#
# Hand-written, not generated by autoconf: there is no C to probe for, and the
# real job here is locating two language toolchains and deciding which package
# formats this host can actually produce. It follows the GNU conventions that
# matter — --prefix and friends, DESTDIR support in the Makefile, and feature
# detection that degrades rather than aborts.
#
#   ./configure && make && make check && sudo make install
#
# Writes config.mk, which the Makefile includes.

set -eu

srcdir=$(cd "$(dirname "$0")" && pwd)

# ---------------------------------------------------------------- defaults --
prefix=/usr/local
exec_prefix=
bindir=
libdir=
datadir=
sysconfdir=
systemdunitdir=

java_home=
javafx_jmods=
container_engine=
glibc_floor=2.28
build_console=auto
build_agent=auto
host_arch=

PACKAGE=bwtest

usage() {
    cat <<EOF
Usage: ./configure [OPTION]...

Installation directories:
  --prefix=DIR            install architecture-independent files in DIR
                          [$prefix]
  --exec-prefix=DIR       install architecture-dependent files in DIR [PREFIX]
  --bindir=DIR            user executables [EPREFIX/bin]
  --libdir=DIR            object code libraries [EPREFIX/lib]
  --datadir=DIR           read-only data [PREFIX/share]
  --sysconfdir=DIR        read-only single-machine data [PREFIX/etc]
  --with-systemdunitdir=DIR
                          systemd unit directory [PREFIX/lib/systemd/system]

Optional features:
  --enable-console / --disable-console   build the JavaFX console [auto]
  --enable-agent   / --disable-agent     build the Rust agent [auto]

Optional packages:
  --with-java-home=DIR    JDK to build with (needs jpackage, JDK 21+)
  --with-javafx-jmods=DIR JavaFX jmods directory, required to package the
                          console. Download from https://openjfx.io — the
                          *jmods* bundle, not the SDK.
  --with-container-engine=CMD
                          podman or docker, for containerised Linux packaging
  --with-glibc-floor=VER  oldest glibc the agent may require [$glibc_floor]
  --host=ARCH             target architecture for packaging (arm64|amd64)

Some influential environment variables:
  JAVA_HOME, JAVAFX_JMODS, MVN, CARGO, MAKEFLAGS

Report bugs to <nicholas.scot.buchanan@gmail.com>.
EOF
}

# ------------------------------------------------------------------ parse ---
for arg do
    case $arg in
        --prefix=*)              prefix=${arg#*=} ;;
        --exec-prefix=*)         exec_prefix=${arg#*=} ;;
        --bindir=*)              bindir=${arg#*=} ;;
        --libdir=*)              libdir=${arg#*=} ;;
        --datadir=*)             datadir=${arg#*=} ;;
        --sysconfdir=*)          sysconfdir=${arg#*=} ;;
        --with-systemdunitdir=*) systemdunitdir=${arg#*=} ;;
        --with-java-home=*)      java_home=${arg#*=} ;;
        --with-javafx-jmods=*)   javafx_jmods=${arg#*=} ;;
        --with-container-engine=*) container_engine=${arg#*=} ;;
        --with-glibc-floor=*)    glibc_floor=${arg#*=} ;;
        --host=*)                host_arch=${arg#*=} ;;
        --enable-console)        build_console=yes ;;
        --disable-console)       build_console=no ;;
        --enable-agent)          build_agent=yes ;;
        --disable-agent)         build_agent=no ;;
        --help|-h)               usage; exit 0 ;;
        --version|-V)            echo "$PACKAGE configure"; exit 0 ;;
        # Accepted and ignored, so autotools-shaped invocations do not fail.
        --build=*|--target=*|--infodir=*|--mandir=*|--docdir=*|\
        --localstatedir=*|--sharedstatedir=*|--libexecdir=*|--includedir=*|\
        --disable-dependency-tracking|--disable-option-checking|--enable-silent-rules)
            ;;
        *) echo "configure: error: unrecognised option: $arg" >&2
           echo "Try './configure --help' for more information." >&2
           exit 1 ;;
    esac
done

: "${exec_prefix:=$prefix}"
: "${bindir:=$exec_prefix/bin}"
: "${libdir:=$exec_prefix/lib}"
: "${datadir:=$prefix/share}"
: "${sysconfdir:=$prefix/etc}"
: "${systemdunitdir:=$prefix/lib/systemd/system}"

# ------------------------------------------------------------------ checks --
missing=""
have() { command -v "$1" >/dev/null 2>&1; }

printf 'checking for a shell... %s\n' "${SHELL:-/bin/sh}"

# Maven
MVN=${MVN:-mvn}
if have "$MVN"; then
    mvn_version=$("$MVN" -v 2>/dev/null | head -1 | awk '{print $3}')
    echo "checking for maven... $MVN ($mvn_version)"
else
    echo "checking for maven... no"
    MVN=
fi

# JDK. jpackage is the part that matters; it arrived in JDK 14 and the
# packages bundle a JDK 21 runtime, so require 21+.
if [ -n "$java_home" ]; then
    JAVA_HOME_SET=$java_home
elif [ -n "${JAVA_HOME:-}" ]; then
    JAVA_HOME_SET=$JAVA_HOME
else
    JAVA_HOME_SET=
fi

if [ -n "$JAVA_HOME_SET" ]; then
    JAVAC=$JAVA_HOME_SET/bin/javac
    JPACKAGE=$JAVA_HOME_SET/bin/jpackage
    JDEPS=$JAVA_HOME_SET/bin/jdeps
else
    JAVAC=javac; JPACKAGE=jpackage; JDEPS=jdeps
fi

if have "$JAVAC"; then
    java_version=$("$JAVAC" -version 2>&1 | awk '{print $2}')
    echo "checking for javac... $JAVAC ($java_version)"
    java_major=${java_version%%.*}
    if [ "${java_major:-0}" -lt 21 ] 2>/dev/null; then
        echo "configure: WARNING: JDK $java_version is older than 21; packaging needs 21+"
    fi
else
    echo "checking for javac... no"
    JAVAC=
fi

have "$JPACKAGE" && echo "checking for jpackage... $JPACKAGE" \
                 || { echo "checking for jpackage... no"; JPACKAGE=; }
have "$JDEPS" && echo "checking for jdeps... $JDEPS" \
              || { echo "checking for jdeps... no"; JDEPS=; }

# Cargo
CARGO=${CARGO:-cargo}
if have "$CARGO"; then
    echo "checking for cargo... $CARGO ($("$CARGO" --version 2>/dev/null | awk '{print $2}'))"
else
    echo "checking for cargo... no"
    CARGO=
fi

# cargo-zigbuild pins the agent's glibc floor so the binary runs on older
# distros than the build host. Optional — without it the agent still builds,
# but inherits this machine's glibc.
if have cargo-zigbuild && have zig; then
    echo "checking for cargo-zigbuild... yes (glibc floor $glibc_floor)"
    HAVE_ZIGBUILD=yes
else
    echo "checking for cargo-zigbuild... no (agent will use the host glibc)"
    HAVE_ZIGBUILD=no
fi

# JavaFX jmods — needed to package the console, not to compile it.
if [ -z "$javafx_jmods" ] && [ -n "${JAVAFX_JMODS:-}" ]; then
    javafx_jmods=$JAVAFX_JMODS
fi
if [ -n "$javafx_jmods" ] && [ -d "$javafx_jmods" ]; then
    if ls "$javafx_jmods"/*.jmod >/dev/null 2>&1; then
        echo "checking for JavaFX jmods... $javafx_jmods"
        # The path is recorded verbatim in config.mk and used at build time,
        # possibly weeks later. A temp directory will be reaped out from under
        # it, and the failure then surfaces as an opaque jdeps error during
        # packaging rather than here. Warn, but do not refuse: a throwaway CI
        # runner unpacking into /tmp is a legitimate use.
        case $javafx_jmods in
            /tmp/*|/private/tmp/*|/var/folders/*)
                echo "configure: WARNING: the jmods path is under a temporary directory." >&2
                echo "  $javafx_jmods" >&2
                echo "  It will be recorded in config.mk and read at build time. If the" >&2
                echo "  system reaps it, 'make app-image'/'deb'/'rpm' break. Prefer a" >&2
                echo "  durable location, e.g. \$HOME/.local/share/." >&2
                ;;
        esac
    else
        echo "configure: error: $javafx_jmods has no .jmod files." >&2
        echo "  That looks like the JavaFX SDK. jpackage needs the *jmods* bundle." >&2
        exit 1
    fi
else
    echo "checking for JavaFX jmods... no (set --with-javafx-jmods to package the console)"
    javafx_jmods=
fi

# Native Linux package tooling
if have rpmbuild; then echo "checking for rpmbuild... yes"; HAVE_RPMBUILD=yes
else echo "checking for rpmbuild... no"; HAVE_RPMBUILD=no; fi
if have dpkg-deb; then echo "checking for dpkg-deb... yes"; HAVE_DPKG=yes
else echo "checking for dpkg-deb... no"; HAVE_DPKG=no; fi
if have nfpm; then echo "checking for nfpm... yes"; HAVE_NFPM=yes
else echo "checking for nfpm... no"; HAVE_NFPM=no; fi

# Container engine, for building Linux packages from any host
if [ -z "$container_engine" ]; then
    if have podman; then container_engine=podman
    elif have docker; then container_engine=docker
    fi
fi
if [ -n "$container_engine" ] && have "$container_engine"; then
    echo "checking for a container engine... $container_engine"
else
    echo "checking for a container engine... no"
    container_engine=
fi

# Host OS and architecture
os=$(uname -s)
case $os in
    Darwin) host_os=macos ;;
    Linux)  host_os=linux ;;
    MINGW*|MSYS*|CYGWIN*) host_os=windows ;;
    *) host_os=unknown ;;
esac
if [ -z "$host_arch" ]; then
    case $(uname -m) in
        arm64|aarch64) host_arch=arm64 ;;
        x86_64|amd64)  host_arch=amd64 ;;
        *) host_arch=unknown ;;
    esac
fi
echo "checking host system type... $host_os/$host_arch"

# The native installer format jpackage can produce here. jpackage cannot
# cross-compile, so this is decided entirely by the build host.
case $host_os in
    macos) native_pkg=dmg ;;
    linux) native_pkg=deb ;;
    windows) native_pkg=msi ;;
    *) native_pkg= ;;
esac
echo "checking native installer format... ${native_pkg:-none}"

# ------------------------------------------------------- resolve features --
if [ "$build_console" = auto ]; then
    if [ -n "$MVN" ] && [ -n "$JAVAC" ]; then build_console=yes; else build_console=no; fi
fi
if [ "$build_agent" = auto ]; then
    if [ -n "$CARGO" ]; then build_agent=yes; else build_agent=no; fi
fi

[ "$build_console" = yes ] && [ -z "$MVN" ] && missing="$missing maven"
[ "$build_console" = yes ] && [ -z "$JAVAC" ] && missing="$missing jdk"
[ "$build_agent" = yes ] && [ -z "$CARGO" ] && missing="$missing cargo"

if [ -n "$missing" ]; then
    echo >&2
    echo "configure: error: required tools not found:$missing" >&2
    echo "  Install them, or disable the component (--disable-console / --disable-agent)." >&2
    exit 1
fi

if [ "$build_console" = no ] && [ "$build_agent" = no ]; then
    echo "configure: error: nothing to build (both components disabled)" >&2
    exit 1
fi

VERSION=$(sed -n 's|.*<version>\(.*\)</version>.*|\1|p' "$srcdir/console/pom.xml" | head -1)
: "${VERSION:=0.0.0}"

# ------------------------------------------------------------ write output --
# Overridable so a containerised build can write its own config without
# clobbering the one belonging to the bind-mounted host repo.
config_out=${CONFIG_MK:-$srcdir/config.mk}

cat > "$config_out" <<EOF
# Generated by ./configure — do not edit.
# Re-run ./configure to regenerate, or 'make distclean' to remove.

PACKAGE        = $PACKAGE
VERSION        = $VERSION

prefix         = $prefix
exec_prefix    = $exec_prefix
bindir         = $bindir
libdir         = $libdir
datadir        = $datadir
sysconfdir     = $sysconfdir
systemdunitdir = $systemdunitdir

MVN            = $MVN
CARGO          = $CARGO
JAVAC          = $JAVAC
JPACKAGE       = $JPACKAGE
JDEPS          = $JDEPS
JAVA_HOME_SET  = $JAVA_HOME_SET
JAVAFX_JMODS   = $javafx_jmods

CONTAINER_ENGINE = $container_engine
GLIBC_FLOOR    = $glibc_floor
HAVE_ZIGBUILD  = $HAVE_ZIGBUILD
HAVE_RPMBUILD  = $HAVE_RPMBUILD
HAVE_DPKG      = $HAVE_DPKG
HAVE_NFPM      = $HAVE_NFPM

HOST_OS        = $host_os
HOST_ARCH      = $host_arch
NATIVE_PKG     = $native_pkg

BUILD_CONSOLE  = $build_console
BUILD_AGENT    = $build_agent
EOF

cat <<EOF

$PACKAGE $VERSION configured:

  host                $host_os/$host_arch
  prefix              $prefix
  console (JavaFX)    $build_console
  agent (Rust)        $build_agent
  JavaFX jmods        ${javafx_jmods:-(not set — 'make app-image' and native packaging unavailable)}
  container engine    ${container_engine:-(none — 'make deb'/'make rpm' unavailable off Linux)}
  agent glibc floor   $glibc_floor$([ "$HAVE_ZIGBUILD" = no ] && echo ' (not enforced: cargo-zigbuild missing)')

Now run 'make' — or 'make help' to see every target.
EOF
