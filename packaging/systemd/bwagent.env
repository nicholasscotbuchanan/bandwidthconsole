# bwagent configuration. Read by the systemd unit; each variable maps onto a
# bwagent command-line flag via clap's `env` support (see agent/src/main.rs).

# host:port of the Bandwidth Console's control listener.
# Defaults to 127.0.0.1:9077, which is only right if the console runs on this
# same machine — set it for any real deployment.
BW_CONSOLE=127.0.0.1:9077

# The address *other agents* dial to reach this one's data plane. Leave it unset
# and the agent uses the local address of its control connection to the console —
# the IP the console actually reached it on, which is correct for most networks.
# Set it only to override that, e.g. when peers must dial a NAT or floating IP
# different from the one the console sees.
#BW_ADVERTISE=

# Friendly agent name shown in the console. Defaults to the hostname.
#BW_NAME=

# Log filter, e.g. debug, or bwagent=debug,quinn=warn.
#RUST_LOG=info
